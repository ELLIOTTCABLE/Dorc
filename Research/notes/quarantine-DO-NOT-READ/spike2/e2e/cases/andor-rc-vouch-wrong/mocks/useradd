#!/bin/sh
# INERT non-conforming-establish mock: simulates `useradd <name>` when the user
# ALREADY EXISTS — logs that it ran, mutates NOTHING, then exits NON-ZERO (real
# useradd's rc 9). The non-zero rc is the whole point: it makes the `|| mkdir`
# fallback fire, so the render-masked verbatim line is SAFE. Were the engine's wrong
# `Replace` ever rendered (a leaf-exact render_apply), useradd would be `:` (rc 0),
# the `||` would not fire, and `mkdir` would wrongly NOT run (the kFAIL-perform pinned
# at observable_matrix::xfail_nonconforming_...).
printf 'ran: %s %s\n' "${0##*/}" "$*" >>"$DORC_LOG"
exit 9
