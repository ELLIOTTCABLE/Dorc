#!/bin/sh
# dorc probe (read-only): reports per-fact convergence, mutates nothing.

# probe: package:nginx#installed
package__check() { dpkg-query -W "$1" >/dev/null 2>&1; }
package__check 'nginx'
# probe: service:nginx#enabled
service__check() { systemctl is-active --quiet "$1"; }
service__check 'nginx'
#!/bin/sh
# dorc apply: the book, with already-converged/dead lines elided (value-preserving stand-in).

# apt-get install -y nginx   # dorc: elided (already converged / dead branch)
true
# systemctl enable nginx   # dorc: elided (already converged / dead branch)
true
echo provisioned
