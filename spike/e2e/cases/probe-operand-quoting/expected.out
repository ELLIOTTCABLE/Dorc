#!/bin/sh
# dorc probe (read-only): reports per-fact convergence, mutates nothing.

# probe: package:web (proxy)#installed
package__check() { dpkg-query -W "$1" >/dev/null 2>&1; }
package__check 'web (proxy)'
# probe: package:x; touch /tmp/PWNED#installed
package__check 'x; touch /tmp/PWNED'
#!/bin/sh
# dorc apply: the book, with already-converged lines elided (replaced by `:`).

apt-get install -y 'web (proxy)'
apt-get install -y 'x; touch /tmp/PWNED'
