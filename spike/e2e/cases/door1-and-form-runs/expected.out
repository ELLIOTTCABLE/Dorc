#!/bin/sh
# dorc probe (read-only): checks per-SITE convergence, mutates nothing.
# When run, emits one results-record per site on stdout (the return channel):
#   site <leafid> effect=<holds|absent|cant-tell> rc=<n>
# effect is derived from the probe command's rc (0=holds, 1=absent, else cant-tell);
# rc is the raw PROBE-command status (opaque to Dorc — the record is the out-of-band lane).

# site 1: pkgstate:nginx#installed
pkgstate_installed__check() { dpkg -s "$1" >/dev/null 2>&1; }
pkgstate_installed__check 'nginx'; _rc=$?; if [ "$_rc" -eq 0 ]; then _e=holds; elif [ "$_rc" -eq 1 ]; then _e=absent; else _e=cant-tell; fi; printf 'site 1 effect=%s rc=%s\n' "$_e" "$_rc"
# site:0 skip-unresolvable
# site:2 skip-unresolvable
#!/bin/sh
# dorc apply: the book, with already-converged/dead lines elided (value-preserving stand-in).

# door1-and-form-runs (door-1 && POLE, charter 20V §4 / note 215): the `&&` companion-pole
# to door1-and-form. Here the `dpkg -s nginx` Query guard HOLDS (rc 0), so `&&` PROCEEDS ⇒
# the `{ … }` block is LIVE and runs. This pins the `&&` direction's OTHER pole (the dual of
# door1-cascade-diverged-runs for `||`): the identical `&& { … }` shape that folded whole in
# door1-and-form (guard failed) runs whole here (guard held), proving the `&&` deadness is
# PROBE-KEYED, never structural.
#
# The guard substitutes to `true` (rc 0, its probe-sourced value); the block is kept verbatim
# (its controller is live). Renders `true && { systemctl reload nginx; }`; the systemctl
# reload runs (the block's single command), the artifact exits 0 (the live block's last rc),
# so the exec gate accepts it (contrast door1-and-form, whose failing guard exits non-zero ⇒
# analysis-only). run-set: `systemctl reload nginx`. HOST: nginx installed (the guard holds).
set -e
true && { systemctl reload nginx; }   # dorc: elided [dpkg -s nginx >/dev/null 2>&1] (already converged / dead branch)
