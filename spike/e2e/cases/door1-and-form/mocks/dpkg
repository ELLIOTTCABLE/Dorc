#!/bin/sh
# INERT shim for `dpkg` — the pkgstate kind's probe (`dpkg -s <pkg>`; $2=pkg). The mock
# host has nginx ABSENT (rc 1), so the probe records `site 1 effect=absent rc=1` and the
# `&&` guard FAILS ⇒ the block is dead. Read-only; logs argv. NB: the APPLY artifact does
# NOT invoke dpkg (the guard is substituted to `false`); only the PROBE runs it (gate-1).
printf 'ran: %s %s\n' "${0##*/}" "$*" >>"$DORC_LOG"
exit 1   # nginx absent ⇒ guard fails ⇒ `&&` short-circuits the dead block
