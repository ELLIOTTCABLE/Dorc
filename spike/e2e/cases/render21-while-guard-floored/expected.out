#!/bin/sh
# dorc probe (read-only): checks per-SITE convergence, mutates nothing.
# When run, emits one results-record per site on stdout (the return channel):
#   site <leafid> effect=<holds|absent|cant-tell> rc=<n>
# effect is derived from the probe command's rc (0=holds, 1=absent, else cant-tell);
# rc is the raw PROBE-command status (opaque to Dorc — the record is the out-of-band lane).

# site:0 skip-unresolvable
# site:1 skip-unresolvable
#!/bin/sh
# dorc apply: the book, with already-converged/dead lines elided (value-preserving stand-in).

# render21-while-guard-floored (arch-1, note 214 — the while-condition ANTI-POLE): a `while`
# condition that is a converged read-only Query is NEVER substituted, even though the SAME
# guard in an `if` elides (render21-if-guard-query-elides). A loop condition is re-evaluated
# per pass, so the value it consumes is a SEQUENCE no single predicted rc can reproduce, and
# replacing it with a constant is an infinite/zero-iteration disaster — so it consumes
# `Channel::StatusIterated`, which blocks UNCONDITIONALLY (the honest successor to the retired
# `StatusRenderFloor`, keyed on iteration not render capability). The body is `in_loop`-floored
# too. So the whole loop renders VERBATIM: the condition `dpkg -s nginx` runs every pass, the
# body runs every iteration. (The mock dpkg exits 1 so the loop runs ZERO times and terminates;
# a holds would loop forever — the disaster StatusIterated exists to prevent.) The in-loop
# Query condition is also excluded from probe compilation (task-L2 item-6b), so the probe ships
# no resolvable site here.
while dpkg -s nginx >/dev/null 2>&1
do
   echo checking
done
