#!/bin/sh
# INERT probe shim for `find` (the pkgindex kind's freshness probe runs
# `test -n "$(find /var/lib/apt/lists/ … -newermt '-1 hour')"`). This mock host's apt
# lists ARE fresh, so the shim prints one matching path ⇒ `test -n` is true ⇒ the
# pkgindex check maps to `holds` (fixture site 5). Authoring the fixture AND the shim
# together for a fresh-host mock is honest (not retro-fabrication — contrast the existing
# exec-singleton-update, whose fixture asserts a real host; tc-find-shim, 20G). Read-only.
printf 'ran: %s %s\n' "${0##*/}" "$*" >>"$DORC_LOG"
printf '%s\n' '/var/lib/apt/lists/deb.debian.org_dists_stable_InRelease'
exit 0
