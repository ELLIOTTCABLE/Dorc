#!/bin/sh
# INERT shim for `apt-get` — the fold-dead install KEPT VERBATIM behind the refused
# heredoc guard. On this (agreeing) host the live guard exits 0, so the `||` never fires:
# it must NOT appear in the run-set. It logs only if it (wrongly) runs.
printf 'ran: %s %s\n' "${0##*/}" "$*" >>"$DORC_LOG"
exit 0
