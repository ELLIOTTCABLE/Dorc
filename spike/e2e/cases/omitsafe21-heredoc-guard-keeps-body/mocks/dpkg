#!/bin/sh
# INERT shim for `dpkg` — the pkgstate probe AND the apply's KEPT (render-refused) live
# guard. The mock host has nginx INSTALLED (rc 0): probe parity holds (site 1 holds rc=0)
# and the live guard short-circuits past the kept install at apply time. Read-only; logs.
printf 'ran: %s %s\n' "${0##*/}" "$*" >>"$DORC_LOG"
case $2 in
  nginx) exit 0 ;;  # installed ⇒ guard holds, both at probe and at apply
  *)     exit 1 ;;
esac
