#!/bin/sh
# INERT shim for `systemctl` вАФ the enabledвЙ†active host. Logs the argv (for the run-set),
# mutates NOTHING. The PROBE forms answer DISTINCTLY (the find-1 fix made visible): nginx
# is enabled (is-enabled вЗТ rc 0 вЗТ holds) but NOT active (is-active вЗТ rc 1 вЗТ absent). The
# mutating verbs (enable/start) just log and exit 0.
. "${0%/*}/.log"; _dorc_logged "$@"
case $1 in
  is-enabled) exit 0 ;;  # nginx enabled on this host вЗТ holds
  is-active)  exit 1 ;;  # вА¶but NOT active вЗТ absent (so `start` must run)
esac
exit 0
