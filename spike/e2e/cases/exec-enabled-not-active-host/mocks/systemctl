#!/bin/sh
# INERT shim for `systemctl` ‚Äî the enabled‚âÝactive host. Logs the argv (for the run-set),
# mutates NOTHING. The PROBE forms answer DISTINCTLY (the find-1 fix made visible): nginx
# is enabled (is-enabled ‚áí rc 0 ‚áí holds) but NOT active (is-active ‚áí rc 1 ‚áí absent). The
# mutating verbs (enable/start) just log and exit 0.
printf 'ran: %s %s\n' "${0##*/}" "$*" >>"$DORC_LOG"
case $1 in
  is-enabled) exit 0 ;;  # nginx enabled on this host ‚áí holds
  is-active)  exit 1 ;;  # ‚Ä¶but NOT active ‚áí absent (so `start` must run)
esac
exit 0
