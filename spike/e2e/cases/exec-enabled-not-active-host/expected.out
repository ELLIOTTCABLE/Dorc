#!/bin/sh
# dorc probe (read-only): checks per-SITE convergence, mutates nothing.
# When run, emits one results-record per site on stdout (the return channel):
#   site <leafid> effect=<holds|absent|cant-tell> rc=<n>
# effect is derived from the probe command's rc (0=holds, 1=absent, else cant-tell);
# rc is the raw PROBE-command status (opaque to Dorc — the record is the out-of-band lane).

# site 0: service:nginx#enabled
service_enabled__check() { systemctl is-enabled --quiet "$1"; }
service_enabled__check 'nginx'; _rc=$?; if [ "$_rc" -eq 0 ]; then _e=holds; elif [ "$_rc" -eq 1 ]; then _e=absent; else _e=cant-tell; fi; printf 'site 0 effect=%s rc=%s\n' "$_e" "$_rc"
# site 1: service:nginx#active
service_active__check() { systemctl is-active --quiet "$1"; }
service_active__check 'nginx'; _rc=$?; if [ "$_rc" -eq 0 ]; then _e=holds; elif [ "$_rc" -eq 1 ]; then _e=absent; else _e=cant-tell; fi; printf 'site 1 effect=%s rc=%s\n' "$_e" "$_rc"
#!/bin/sh
# dorc apply: the book, with already-converged/dead lines elided (value-preserving stand-in).

true   # dorc: elided [systemctl enable nginx] (already converged / dead branch)
systemctl start nginx
