# newline-safe argv logger for the inert mock shims (slice-4). Sourced by each shim via
# `. "${0%/*}/.log"` (the shim's own dir); a DOTFILE so gate-5/gate-6's `ls`-derived shimset
# never lists it. Replaces the old inline `printf 'ran: %s %s\n' "${0##*/}" "$*"` — an arg with
# an embedded NEWLINE would split the `ran:` line and silently break every line-based compare
# (exec_check, gate-5, gate-6). Shims run under PATH=mocks-only ⇒ BUILTINS ONLY (no sed/awk).
#
# GRAMMAR (what expected.ran goldens carry): one `ran: <name> <arg>…` line per invocation; each
# arg is encoded — a literal backslash as `\\`, an embedded newline as the two chars `\n`. The
# two passes run in THIS order (backslash first) so a newline's encoded `\n` backslash is not
# re-doubled. A newline-free, backslash-free argv encodes to itself ⇒ byte-identical to the old
# format (per-arg space-join == the old `"$*"` join) ⇒ zero golden churn.
_dorc_logged() {
  _dl_out="ran: ${0##*/}"
  for _dl_a in "$@"; do
    _dl_o=""                                          # pass 1: \ -> \\
    while case $_dl_a in *\\*) true ;; *) false ;; esac; do
      _dl_o="$_dl_o${_dl_a%%\\*}\\\\"; _dl_a=${_dl_a#*\\}
    done
    _dl_a="$_dl_o$_dl_a"
    _dl_o=""                                          # pass 2: newline -> \n
    while case $_dl_a in *"$_DL_NL"*) true ;; *) false ;; esac; do
      _dl_o="$_dl_o${_dl_a%%"$_DL_NL"*}\\n"; _dl_a=${_dl_a#*"$_DL_NL"}
    done
    _dl_out="$_dl_out $_dl_o$_dl_a"
  done
  printf '%s\n' "$_dl_out" >>"$DORC_LOG"
}
_DL_NL='
'
