#!/bin/sh
# dorc probe (read-only): checks per-SITE convergence, mutates nothing.
# When run, emits one results-record per site on stdout (the return channel):
#   site <leafid> effect=<holds|absent|cant-tell> rc=<n>
# effect is derived from the probe command's rc (0=holds, 1=absent, else cant-tell);
# rc is the raw PROBE-command status (opaque to Dorc — the record is the out-of-band lane).

# site 1: pkgstate:nginx#installed
pkgstate_installed__check() { dpkg -s "$1" >/dev/null 2>&1; }
pkgstate_installed__check 'nginx'; _rc=$?; if [ "$_rc" -eq 0 ]; then _e=holds; elif [ "$_rc" -eq 1 ]; then _e=absent; else _e=cant-tell; fi; printf 'site 1 effect=%s rc=%s\n' "$_e" "$_rc"
# site:0 skip-unresolvable
# site:2 skip-unresolvable
# site:3 skip-unresolvable
# site:4 skip-unresolvable
# site:5 skip-unresolvable
#!/bin/sh
# dorc apply: the book, with already-converged/dead lines elided (value-preserving stand-in).

# door1-cascade-multistatement (door-1 NESTED REGION, charter 20V §4 / note 215): the
# guarded block has 3+ statements, one of them an inner `if`. When the `dpkg -s nginx`
# Query guard holds (rc 0), the `|| { … }` branch is DEAD ⇒ the fold's `kill_rec` walks
# the WHOLE brace group and kills every leaf in the nested region: the sed, BOTH leaves of
# the inner `if` (its `[ -f … ]` test condition AND its `cp` then-body), and the trailing
# systemctl restart. None of them needs rc-provenance of its own — they are all
# unreachable. The cascade does not stop at the block's top level; it descends into the
# inner construct (the `kill_rec` Group→If→Simple recursion).
#
# Renders `true || { :; if :; then :; fi; :; }`, dash-clean: the inner `if`'s arms become
# `:` (never empty — the span-edit substitutes each leaf, never deletes a clause). Run-set
# EMPTY. HOST: nginx installed (the guard holds).
set -e
true || {   # dorc: elided [dpkg -s nginx >/dev/null 2>&1] (already converged / dead branch)
   :   # dorc: elided [sed -i 's/^.*PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config] (already converged / dead branch)
   if :; then :; fi   # dorc: elided [[ -f /etc/ssh/sshd_config.bak ]; cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak] (already converged / dead branch)
   :   # dorc: elided [systemctl restart sshd] (already converged / dead branch)
}
