#!/bin/sh
# INERT mock (ap-2 exec harness): logs that it ran, mutates NOTHING, exits 0. Under
# PATH=mocks-only this shim is the only thing that runs, so executing a rendered apply is
# provably safe. `${0##*/}` reads the invoked name with no external command.
printf 'ran: %s %s\n' "${0##*/}" "$*" >>"$DORC_LOG"
exit 0
