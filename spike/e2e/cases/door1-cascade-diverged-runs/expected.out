#!/bin/sh
# dorc probe (read-only): checks per-SITE convergence, mutates nothing.
# When run, emits one results-record per site on stdout (the return channel):
#   site <leafid> effect=<holds|absent|cant-tell> rc=<n>
# effect is derived from the probe command's rc (0=holds, 1=absent, else cant-tell);
# rc is the raw PROBE-command status (opaque to Dorc — the record is the out-of-band lane).

# site 1: pkgstate:nginx#installed
pkgstate_installed__check() { dpkg -s "$1" >/dev/null 2>&1; }
pkgstate_installed__check 'nginx'; _rc=$?; if [ "$_rc" -eq 0 ]; then _e=holds; elif [ "$_rc" -eq 1 ]; then _e=absent; else _e=cant-tell; fi; printf 'site 1 effect=%s rc=%s\n' "$_e" "$_rc"
# site:0 skip-unresolvable
# site:2 skip-unresolvable
# site:3 skip-unresolvable
#!/bin/sh
# dorc apply: the book, with already-converged/dead lines elided (value-preserving stand-in).

# door1-cascade-diverged-runs (door-1 POLE, charter 20V §4 / note 215): the SAME book as
# door1-cascade-block-elides, but the host is DIVERGED — nginx is absent (the guard fails,
# rc 1). The fold reads the guard's known rc 1 ⇒ the `||` FIRES ⇒ the `{ … }` block is
# LIVE ⇒ BOTH block commands run (the sed AND the systemctl restart). This is the pole that
# proves dead-branch elision is PROBE-KEYED, never structural: the identical `|| { … }`
# shape that folded whole in the converged case runs whole here, because the guard's
# probed rc differs. The restart is NOT vouched-for by any state-probe — it runs because
# the branch is reachable, exactly the R2-CHANGEDELTA distinction made visible.
#
# The guard substitutes to its exact stand-in `false` (rc 1, the probe-sourced Query
# value); the block is kept verbatim (its controller is live ⇒ the runtime guard gates it).
# Renders `false || { sed …; systemctl restart sshd; }`. HOST: nginx absent (guard fails).
set -e
false || { sed -i 's/^.*PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config; systemctl restart sshd; }   # dorc: elided [dpkg -s nginx >/dev/null 2>&1] (already converged / dead branch)
