#!/bin/sh
# INERT probe shim (gate-1 parity): the `package` kind's probe runs `dpkg-query -W <pkg>`.
# The fixture reports nginx as `holds` (installed), so this shim exits 0 ⇒ the
# `package__check` wrapper maps rc 0 → `holds`, reproducing the authored probe-results.txt.
# Mutates nothing (read-only query); logs for symmetry with the apply shims.
printf 'ran: %s %s\n' "${0##*/}" "$*" >>"$DORC_LOG"
exit 0
