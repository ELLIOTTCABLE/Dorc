#!/bin/sh
# dorc probe (read-only): checks per-SITE convergence, mutates nothing.
# When run, emits one results-record per site on stdout (the return channel):
#   site <leafid> effect=<holds|absent|cant-tell> rc=<n>
# effect is derived from the probe command's rc (0=holds, 1=absent, else cant-tell);
# rc is the raw PROBE-command status (opaque to Dorc — the record is the out-of-band lane).

# site 1: package:nginx#installed
package_installed__check() { dpkg-query -W "$1" >/dev/null 2>&1; }
package_installed__check 'nginx'; _rc=$?; if [ "$_rc" -eq 0 ]; then _e=holds; elif [ "$_rc" -eq 1 ]; then _e=absent; else _e=cant-tell; fi; printf 'site 1 effect=%s rc=%s\n' "$_e" "$_rc"
# site:0 skip-unresolvable
# site:2 skip-unresolvable
#!/bin/sh
# dorc apply: the book, with already-converged/dead lines elided (value-preserving stand-in).

# door3-or-true-diverged-runs (door-3, charter 20V §4 / note 213): door-3 clears ONLY the
# Status channel; the Effect channel still gates. The `|| true` marks the install's rc
# `StatusInvariant` (never blocks), but the host is DIVERGED (nginx absent), so the
# convergence check refuses the license ⇒ the install RUNS for real. The `|| true` swallows
# its rc under `set -e` (the left of `||` is errexit-exempt), so a non-zero install does not
# abort the book. Proof that door-3 is NOT an elision-license relaxation: Effect still gates.
set -e
apt-get install -y nginx || true
